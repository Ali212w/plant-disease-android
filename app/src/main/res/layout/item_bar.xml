<?xml version="1.0" encoding="utf-8"?>
<!-- عنصر شريط الاحتمالية في النتائج -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="10dp">

    <!-- اسم الفئة + النسبة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvBarName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvBarValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- شريط التقدم -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="8dp">

        <!-- المسار (Track) -->
        <View
            android:id="@+id/viewBarTrack"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@drawable/bar_track_bg" />

        <!-- الملء (Fill) -->
        <View
            android:id="@+id/viewBarFill"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:background="@drawable/bar_fill_bg" />
    </FrameLayout>

</LinearLayout>
