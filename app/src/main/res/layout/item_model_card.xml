<?xml version="1.0" encoding="utf-8"?>
<!-- عنصر بطاقة نموذج -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardModel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_surface2"
    app:cardCornerRadius="14dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- النقطة الملونة -->
        <View
            android:id="@+id/modelDot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_green" />

        <!-- معلومات النموذج -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvModelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvModelDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <!-- حجم الملف -->
            <TextView
                android:id="@+id/tvModelSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="@color/cyan"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvModelWarn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="⚠️ الملف غير موجود"
                android:textColor="#EF4444"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Badge النوع -->
        <TextView
            android:id="@+id/tvModelBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_tag"
            android:fontFamily="sans-serif-black"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textSize="10sp" />

        <!-- زر التحميل (للنماذج غير المحملة من GitHub) -->
        <TextView
            android:id="@+id/btnDownloadModel"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="⬇️"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone" />

        <!-- زر الحذف (للنماذج المحملة) -->
        <TextView
            android:id="@+id/btnDeleteModel"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="🗑️"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
