<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Theme -->
    <style name="Theme.PlantDisease" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/bg_surface3</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorSurfaceVariant">@color/bg_surface2</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_muted</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorOutline">@color/border</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:layoutDirection">rtl</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.PlantDisease.Splash" parent="Theme.PlantDisease">
        <item name="android:windowBackground">@drawable/splash_bg</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Circle ShapeAppearance -->
    <style name="Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.PlantDisease.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bg_surface</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="android:elevation">8dp</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.PlantDisease.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- Button Primary -->
    <style name="Widget.PlantDisease.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/green_primary</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>

    <!-- Button Outline -->
    <style name="Widget.PlantDisease.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="backgroundTint">@color/bg_surface3</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>

</resources>
